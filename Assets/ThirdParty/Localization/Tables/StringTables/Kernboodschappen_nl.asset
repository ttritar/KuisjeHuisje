  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Kernboodschappen_nl
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: nl
  m_SharedData: {fileID: 11400000, guid: 67eb1ecfdb1bc4d449b4b3fb2015b2be, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 9811185664
    m_Localized: Het is niet jouw schuld.
    m_Metadata:
      m_Items: []
  - m_Id: 251075940352
    m_Localized: Je bent niet de enige.
    m_Metadata:
      m_Items: []
  - m_Id: 443623854080
    m_Localized: Je mag erover praten
    m_Metadata:
      m_Items: []
  - m_Id: 581436100608
    m_Localized: Je staat er niet alleen voor.
    m_Metadata:
      m_Items: []
  - m_Id: 685811355648
    m_Localized: Je bent niet verantwoordelijk voor de ruzies tussen jouw ouders.
    m_Metadata:
      m_Items: []
  - m_Id: 837607411712
    m_Localized: Veel kinderen groeien op in een gezin waar er veel heftige ruzies
      zijn.
    m_Metadata:
      m_Items: []
  - m_Id: 922168774656
    m_Localized: We weten dat het moeilijk is en dat je niemand wil kwetsen.
    m_Metadata:
      m_Items: []
  - m_Id: 1027890401280
    m_Localized: Samen gaan we op zoek naar mensen die jou kunnen steunen.
    m_Metadata:
      m_Items: []
  - m_Id: 12033890897920
    m_Localized: Jouw gevoelens mogen er zijn.
    m_Metadata:
      m_Items: []
  - m_Id: 12543612080128
    m_Localized: Het is normaal dat je je bang, boos, verdrietig, bezorgd, ... voelt.
    m_Metadata:
      m_Items: []
  - m_Id: 12587526443008
    m_Localized: Mensen mogen elkaar geen pijn doen.
    m_Metadata:
      m_Items: []
  - m_Id: 12600746889216
    m_Localized: Het is belangrijk dat dit stopt.
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
