  m_SharedData: {fileID: 11400000, guid: 67eb1ecfdb1bc4d449b4b3fb2015b2be, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 9811185664
    m_Localized: "It\u2019s not your fault."
    m_Metadata:
      m_Items: []
  - m_Id: 685811355648
    m_Localized: You are not responsible for the fights between your parents.
    m_Metadata:
      m_Items: []
  - m_Id: 251075940352
    m_Localized: You are not the only one.
    m_Metadata:
      m_Items: []
  - m_Id: 837607411712
    m_Localized: Many children grow up in a home where there are big arguments.
    m_Metadata:
      m_Items: []
  - m_Id: 443623854080
    m_Localized: You are allowed to talk about it.
    m_Metadata:
      m_Items: []
  - m_Id: 922168774656
    m_Localized: "We know it\u2019s hard and that you don\u2019t want to hurt anyone."
    m_Metadata:
      m_Items: []
  - m_Id: 581436100608
    m_Localized: You are not alone.
    m_Metadata:
      m_Items: []
  - m_Id: 1027890401280
    m_Localized: Together we will look for people who can support you.
    m_Metadata:
      m_Items: []
  - m_Id: 12033890897920
    m_Localized: Your feelings are allowed to be there.
    m_Metadata:
      m_Items: []
  - m_Id: 12543612080128
    m_Localized: "It\u2019s normal to feel scared, angry, sad, worried, \u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 12587526443008
    m_Localized: People are not allowed to hurt each other.
    m_Metadata:
      m_Items: []
  - m_Id: 12600746889216
    m_Localized: "It\u2019s important that this stops."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
