  m_SharedData: {fileID: 11400000, guid: 67eb1ecfdb1bc4d449b4b3fb2015b2be, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 9811185664
    m_Localized: "Ce n\u2019est pas ta faute."
    m_Metadata:
      m_Items: []
  - m_Id: 685811355648
    m_Localized: "Tu n\u2019es pas responsable des disputes entre tes parents."
    m_Metadata:
      m_Items: []
  - m_Id: 251075940352
    m_Localized: "Tu n\u2019es pas le seul / la seule."
    m_Metadata:
      m_Items: []
  - m_Id: 837607411712
    m_Localized: "Beaucoup d\u2019enfants grandissent dans une famille o\xF9 il y
      a de grosses disputes."
    m_Metadata:
      m_Items: []
  - m_Id: 443623854080
    m_Localized: Tu peux en parler.
    m_Metadata:
      m_Items: []
  - m_Id: 922168774656
    m_Localized: "Nous savons que c\u2019est difficile et que tu ne veux blesser
      personne."
    m_Metadata:
      m_Items: []
  - m_Id: 581436100608
    m_Localized: "Tu n\u2019es pas tout seul / toute seule."
    m_Metadata:
      m_Items: []
  - m_Id: 1027890401280
    m_Localized: Ensemble, nous chercherons des personnes qui peuvent te soutenir.
    m_Metadata:
      m_Items: []
  - m_Id: 12033890897920
    m_Localized: "Tes \xE9motions ont le droit d\u2019exister."
    m_Metadata:
      m_Items: []
  - m_Id: 12543612080128
    m_Localized: "C\u2019est normal de te sentir effray\xE9, f\xE2ch\xE9, triste,
      inquiet, \u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 12600746889216
    m_Localized: "Il est important que cela s\u2019arr\xEAte."
    m_Metadata:
      m_Items: []
  - m_Id: 12587526443008
    m_Localized: "Les gens n\u2019ont pas le droit de se faire du mal."
    m_Metadata:
      m_Items: []
  references:
    version: 2
